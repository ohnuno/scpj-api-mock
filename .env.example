# GitHub Secrets として登録する環境変数のサンプル
# 実際の値はリポジトリの Settings → Secrets and variables → Actions で登録すること
# このファイルをコミットしても問題ないが、実際の値を書いた .env はコミットしないこと

# サービスアカウントの JSON キー全体をそのまま貼り付ける
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# 変数管理スプレッドシートの ID（URLの /spreadsheets/d/{ID}/ 部分）
CONFIG_SHEET_ID=your-config-spreadsheet-id-here

# SendGrid の API キー（差異レポートメール送信用）
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
